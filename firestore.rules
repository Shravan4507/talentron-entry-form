rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety check for Admin status
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // REGISTRATIONS: Public can create and read, only Admin can write/delete
    match /registrations/{regId} {
      allow create, read: if true;
      allow update: if isAdmin() || (resource.data.status == 'payment_upload_pending' || resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // CONTACT MESSAGES: Public can create, only Admin can manage
    match /contact_messages/{msgId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // STALL INQUIRIES: Public can create, only Admin can manage
    match /stall_inquiries/{msgId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // TRANSACTION LOCKS: Used for unique TxID checks
    match /transaction_locks/{lockId} {
      allow get, create: if true;
      allow list, update, delete: if isAdmin();
    }

    // EMAIL QUEUE: Used to trigger confirmation emails
    match /mail/{mailId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // METADATA & ADMIN CONFIG: High security
    match /metadata/{docId} {
      allow read, write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if true;
      allow write: if false;
    }

    match /audit_logs/{logId} {
      allow read, create: if isAdmin();
    }
  }
}
