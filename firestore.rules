rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // THE MASTER ADMIN OVERRIDE
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'hrAEy4UJ8zWKqUXWSqpy4oh3ufk1'; 
    }

    // REGISTRATIONS COLLECTION
    match /registrations/{registrationId} {
      // Allow participants to submit (Create) and finish (Update) their own entry
      allow create, update: if true; 

      // Allow the DUPLICATE CHECK query (Limit must be small to prevent scraping)
      allow list: if isAdmin() || request.query.limit <= 2;

      // Allow fetching a specific doc if they have the ID (e.g., confirmation pages)
      allow get: if true;

      // Only YOU can delete or list the whole database for export
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }
    
    // TRANSACTION LOCKS
    match /transaction_locks/{txId} {
      allow get, create: if true; // Public check & lock
      allow list, delete, update: if isAdmin(); // Admin only management
    }
  }
}